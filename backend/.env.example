SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# DATABASE_URL defaults to sqlite:///backend/eventsmister.db when omitted.
# UPLOAD_DIRECTORY defaults to backend/uploads when omitted.
# External discovery remains disabled for providers whose key is blank.
SKIDDLE_API_KEY=
TICKETMASTER_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EXTERNAL_EVENTS_CACHE_SECONDS=900
EXTERNAL_EVENTS_TIMEOUT_SECONDS=8
